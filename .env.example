# ============================================================================
# SYGNALIST ENVIRONMENT VARIABLES
# Copy to .env.local for local development, or set in Vercel dashboard
# ============================================================================

# ── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── OpenAI (required for enrichment, GoodFit, resume parsing) ───────────────
OPENAI_API_KEY=sk-...

# ── Job Sources: Adzuna (free tier: 5K requests/month) ──────────────────────
# Register: https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Job Sources: Jooble (free) ──────────────────────────────────────────────
# Register: https://jooble.org/api/about
JOOBLE_API_KEY=

# ── Job Sources: RapidAPI (powers JSearch + LinkedIn) ───────────────────────
# Register: https://rapidapi.com — subscribe to both APIs below
# JSearch: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# LinkedIn: https://rapidapi.com/jaypat87/api/linkedin-job-search-api
RAPIDAPI_KEY=
RAPIDAPI_HOST_JSEARCH=active-jobs-db.p.rapidapi.com
RAPIDAPI_HOST_LINKEDIN=linkedin-job-search-api.p.rapidapi.com

# ── Email: Gmail SMTP (for client invites + messages) ───────────────────────
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=

# ── Email: Gmail API (for inbox ingest + reply polling) ─────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Email: Alert notifications (for critical error alerts) ──────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=

# ── Cron (Vercel cron job authentication) ───────────────────────────────────
CRON_SECRET=
